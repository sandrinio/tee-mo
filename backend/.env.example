# Tee-Mo backend environment variables
# Copy this file to .env and fill in the values.
# The source of truth is the repo-root .env — copy only the backend-relevant keys here.
# NEVER commit a real .env file.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DEBUG=false
CORS_ORIGINS=http://localhost:5173

# Base URL of the SPA, used to build post-OAuth redirect targets (e.g. Drive connect).
# Dev (API on :8000, Vite on :5173): http://localhost:5173
# Prod same-origin (API and SPA on one host): leave empty — callback emits a
#   relative /app?... redirect that resolves to the request host.
FRONTEND_URL=http://localhost:5173
